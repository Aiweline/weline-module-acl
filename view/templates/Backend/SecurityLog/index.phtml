<?php
/**
 * 安全日志列表页面 - 内容模板
 *
 * @var \Weline\Framework\View\Template $this
 * @var array $logs
 * @var int $total
 * @var int $page
 * @var int $limit
 * @var int $total_pages
 * @var string $event_type
 * @var string $keyword
 * @var array $event_types
 */

$logs = $logs ?? [];
$total = (int)($total ?? 0);
$page = (int)($page ?? 1);
$limit = (int)($limit ?? 20);
$totalPages = (int)($total_pages ?? 0);
$eventType = $event_type ?? '';
$keyword = $keyword ?? '';
$eventTypes = $event_types ?? [];
// 闭包替代全局函数，避免模板被多次包含时 Cannot redeclare function（禁止在模板中定义全局函数）
$getEventTypeBadgeClass = function ($eventType) {
    $classes = [
        \Weline\Acl\Model\SecurityLog::EVENT_LOGIN_FAILED => 'danger',
        \Weline\Acl\Model\SecurityLog::EVENT_LOGIN_SUCCESS => 'success',
        \Weline\Acl\Model\SecurityLog::EVENT_PERMISSION_DENIED => 'warning',
        \Weline\Acl\Model\SecurityLog::EVENT_ACL_VIOLATION => 'danger',
        \Weline\Acl\Model\SecurityLog::EVENT_SUSPICIOUS_ACTIVITY => 'warning',
    ];
    return $classes[$eventType] ?? 'secondary';
};
?>
<!-- 页面标题 -->
<div class="row">
    <div class="col-12">
        <div class="page-title-box d-sm-flex align-items-center justify-content-between">
            <h4 class="mb-sm-0 font-size-18"><lang>安全日志</lang></h4>
        </div>
    </div>
</div>

<!-- 消息提示区域 -->
<div class='row'>
    <div class="col-12">
        <template>Weline_Component::message.phtml</template>
    </div>
</div>

<!-- 搜索和筛选 -->
<div class="row">
    <div class="col-xl-12">
        <div class="card">
            <div class="card-body">
                <form method="get" action="<?= $this->getBackendUrl('*/backend/security-log') ?>" class="row g-3">
                    <div class="col-md-3">
                        <label class="form-label"><lang>事件类型</lang></label>
                        <select class="form-select" name="event_type">
                            <option value=""><lang>全部</lang></option>
                            <?php foreach ($eventTypes as $type => $label): ?>
                            <option value="<?= $type ?>" <?= $eventType === $type ? 'selected' : '' ?>>
                                <?= htmlspecialchars($label) ?>
                            </option>
                            <?php endforeach; ?>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label"><lang>关键词</lang></label>
                        <input type="text" class="form-control" name="keyword" value="<?= htmlspecialchars($keyword) ?>" 
                               placeholder="<?= __('搜索消息或IP地址') ?>">
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">&nbsp;</label>
                        <div>
                            <button type="submit" class="btn btn-primary">
                                <i class="mdi mdi-magnify me-2"></i><lang>搜索</lang>
                            </button>
                            <a href="<?= $this->getBackendUrl('*/backend/security-log') ?>" class="btn btn-secondary">
                                <i class="mdi mdi-refresh me-2"></i><lang>重置</lang>
                            </a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- 日志列表 -->
<div class="row">
    <div class="col-xl-12">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title mb-4"><lang>日志列表</lang></h4>
                
                <?php if (!empty($logs)): ?>
                <div class="table-responsive">
                    <table class="table table-hover table-striped align-middle table-nowrap mb-0">
                        <thead class="table-light">
                            <tr>
                                <th><lang>ID</lang></th>
                                <th><lang>事件类型</lang></th>
                                <th><lang>用户ID</lang></th>
                                <th><lang>IP地址</lang></th>
                                <th><lang>消息</lang></th>
                                <th><lang>创建时间</lang></th>
                                <th><lang>操作</lang></th>
                            </tr>
                        </thead>
                        <tbody>
                            <?php foreach ($logs as $log): ?>
                            <?php 
                            $logData = is_object($log) ? $log->getData() : $log;
                            $eventTypeLabel = $eventTypes[$logData['event_type'] ?? ''] ?? $logData['event_type'] ?? '';
                            ?>
                            <tr>
                                <td><?= $logData['log_id'] ?? $logData['id'] ?? '' ?></td>
                                <td>
                                    <span class="badge bg-<?= $getEventTypeBadgeClass($logData['event_type'] ?? '') ?>">
                                        <?= htmlspecialchars($eventTypeLabel) ?>
                                    </span>
                                </td>
                                <td><?= $logData['user_id'] ?? '-' ?></td>
                                <td><?= htmlspecialchars($logData['ip'] ?? '-') ?></td>
                                <td><?= htmlspecialchars($logData['message'] ?? '-') ?></td>
                                <td><?= $logData['created_at'] ?? '-' ?></td>
                                <td>
                                    <button type="button" class="btn btn-sm btn-info" onclick="viewDetails(<?= $logData['log_id'] ?? $logData['id'] ?? 0 ?>)">
                                        <lang>查看详情</lang>
                                    </button>
                                </td>
                            </tr>
                            <?php endforeach; ?>
                        </tbody>
                    </table>
                </div>

                <!-- 分页 -->
                <?php if ($totalPages > 1): ?>
                <div class="row mt-4">
                    <div class="col-sm-12 col-md-5">
                        <div class="dataTables_info">
                            <lang>显示</lang> <?= (($page - 1) * $limit + 1) ?> 
                            <lang>到</lang> <?= min($page * $limit, $total) ?> 
                            <lang>共</lang> <?= $total ?> <lang>条记录</lang>
                        </div>
                    </div>
                    <div class="col-sm-12 col-md-7">
                        <div class="dataTables_paginate paging_simple_numbers float-end">
                            <ul class="pagination">
                                <?php if ($page > 1): ?>
                                <li class="paginate_button page-item previous">
                                    <a href="?page=<?= $page - 1 ?>&event_type=<?= urlencode($eventType) ?>&keyword=<?= urlencode($keyword) ?>" class="page-link">
                                        <lang>上一页</lang>
                                    </a>
                                </li>
                                <?php endif; ?>
                                
                                <?php for ($i = max(1, $page - 2); $i <= min($totalPages, $page + 2); $i++): ?>
                                <li class="paginate_button page-item <?= $i === $page ? 'active' : '' ?>">
                                    <a href="?page=<?= $i ?>&event_type=<?= urlencode($eventType) ?>&keyword=<?= urlencode($keyword) ?>" class="page-link">
                                        <?= $i ?>
                                    </a>
                                </li>
                                <?php endfor; ?>
                                
                                <?php if ($page < $totalPages): ?>
                                <li class="paginate_button page-item next">
                                    <a href="?page=<?= $page + 1 ?>&event_type=<?= urlencode($eventType) ?>&keyword=<?= urlencode($keyword) ?>" class="page-link">
                                        <lang>下一页</lang>
                                    </a>
                                </li>
                                <?php endif; ?>
                            </ul>
                        </div>
                    </div>
                </div>
                <?php endif; ?>

                <?php else: ?>
                <div class="text-center text-muted py-5">
                    <i class="mdi mdi-shield-alert" style="font-size: 48px;"></i>
                    <p class="mt-3"><lang>暂无安全日志记录</lang></p>
                </div>
                <?php endif; ?>
            </div>
        </div>
    </div>
</div>

<script>
(function() {
    'use strict';
    
    window.viewDetails = function(logId) {
        BackendToast.info('<?= __('查看日志ID：') ?>' + logId);
    };
})();
</script>

