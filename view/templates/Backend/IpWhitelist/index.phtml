 * @var int $page
 * @var int $limit
 * @var int $total_pages
 * @var string $keyword
 */

$items = $items ?? [];
$total = (int)($total ?? 0);
$page = (int)($page ?? 1);
$limit = (int)($limit ?? 20);
$totalPages = (int)($total_pages ?? 0);
$keyword = $keyword ?? '';
?>
<!-- 页面标题 -->
<div class="row">
    <div class="col-12">
        <div class="page-title-box d-sm-flex align-items-center justify-content-between">
            <h4 class="mb-sm-0 font-size-18"><lang>IP白名单</lang></h4>
            <button type="button" class="btn btn-primary" onclick="showAddModal()">
                <i class="mdi mdi-plus me-2"></i><lang>添加IP</lang>
            </button>
        </div>
    </div>
</div>

<!-- 消息提示区域 -->
<div class='row'>
    <div class="col-12">
        <template>Weline_Component::message.phtml</template>
    </div>
</div>

<!-- 搜索 -->
<div class="row">
    <div class="col-xl-12">
        <div class="card">
            <div class="card-body">
                <form method="get" action="<?= $this->getBackendUrl('*/backend/ip-whitelist') ?>" class="row g-3">
                    <div class="col-md-9">
                        <label class="form-label"><lang>关键词</lang></label>
                        <input type="text" class="form-control" name="keyword" value="<?= htmlspecialchars($keyword) ?>" 
                               placeholder="<?= __('搜索IP地址或描述') ?>">
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">&nbsp;</label>
                        <div>
                            <button type="submit" class="btn btn-primary">
                                <i class="mdi mdi-magnify me-2"></i><lang>搜索</lang>
                            </button>
                            <a href="<?= $this->getBackendUrl('*/backend/ip-whitelist') ?>" class="btn btn-secondary">
                                <i class="mdi mdi-refresh me-2"></i><lang>重置</lang>
                            </a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- IP白名单列表 -->
<div class="row">
    <div class="col-xl-12">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title mb-4"><lang>IP白名单列表</lang></h4>
                
                <?php if (!empty($items)): ?>
                <div class="table-responsive">
                    <table class="table table-hover table-striped align-middle table-nowrap mb-0">
                        <thead class="table-light">
                            <tr>
                                <th><lang>ID</lang></th>
                                <th><lang>IP地址</lang></th>
                                <th><lang>描述</lang></th>
                                <th><lang>状态</lang></th>
                                <th><lang>创建时间</lang></th>
                                <th><lang>操作</lang></th>
                            </tr>
                        </thead>
                        <tbody>
                            <?php foreach ($items as $item): ?>
                            <?php 
                            $itemData = is_object($item) ? $item->getData() : $item;
                            $itemId = $itemData['id'] ?? 0;
                            $isActive = (int)($itemData['is_active'] ?? 0);
                            ?>
                            <tr>
                                <td><?= $itemId ?></td>
                                <td><?= htmlspecialchars($itemData['ip'] ?? '-') ?></td>
                                <td><?= htmlspecialchars($itemData['description'] ?? '-') ?></td>
                                <td>
                                    <span class="badge bg-<?= $isActive ? 'success' : 'secondary' ?>">
                                        <?= $isActive ? __('启用') : __('禁用') ?>
                                    </span>
                                </td>
                                <td><?= $itemData['created_at'] ?? '-' ?></td>
                                <td>
                                    <button type="button" class="btn btn-sm btn-primary" onclick="editItem(<?= $itemId ?>)">
                                        <i class="mdi mdi-pencil me-1"></i><lang>编辑</lang>
                                    </button>
                                    <button type="button" class="btn btn-sm btn-<?= $isActive ? 'warning' : 'success' ?>" 
                                            onclick="toggleStatus(<?= $itemId ?>, <?= $isActive ?>)">
                                        <i class="mdi mdi-toggle-switch me-1"></i><?= $isActive ? __('禁用') : __('启用') ?>
                                    </button>
                                    <button type="button" class="btn btn-sm btn-danger" onclick="deleteItem(<?= $itemId ?>)">
                                        <i class="mdi mdi-delete me-1"></i><lang>删除</lang>
                                    </button>
                                </td>
                            </tr>
                            <?php endforeach; ?>
                        </tbody>
                    </table>
                </div>

                <!-- 分页 -->
                <?php if ($totalPages > 1): ?>
                <div class="row mt-4">
                    <div class="col-sm-12 col-md-5">
                        <div class="dataTables_info">
                            <lang>显示</lang> <?= (($page - 1) * $limit + 1) ?> 
                            <lang>到</lang> <?= min($page * $limit, $total) ?> 
                            <lang>共</lang> <?= $total ?> <lang>条记录</lang>
                        </div>
                    </div>
                    <div class="col-sm-12 col-md-7">
                        <div class="dataTables_paginate paging_simple_numbers float-end">
                            <ul class="pagination">
                                <?php if ($page > 1): ?>
                                <li class="paginate_button page-item previous">
                                    <a href="?page=<?= $page - 1 ?>&keyword=<?= urlencode($keyword) ?>" class="page-link">
                                        <lang>上一页</lang>
                                    </a>
                                </li>
                                <?php endif; ?>
                                
                                <?php for ($i = max(1, $page - 2); $i <= min($totalPages, $page + 2); $i++): ?>
                                <li class="paginate_button page-item <?= $i === $page ? 'active' : '' ?>">
                                    <a href="?page=<?= $i ?>&keyword=<?= urlencode($keyword) ?>" class="page-link">
                                        <?= $i ?>
                                    </a>
                                </li>
                                <?php endfor; ?>
                                
                                <?php if ($page < $totalPages): ?>
                                <li class="paginate_button page-item next">
                                    <a href="?page=<?= $page + 1 ?>&keyword=<?= urlencode($keyword) ?>" class="page-link">
                                        <lang>下一页</lang>
                                    </a>
                                </li>
                                <?php endif; ?>
                            </ul>
                        </div>
                    </div>
                </div>
                <?php endif; ?>

                <?php else: ?>
                <div class="text-center text-muted py-5">
                    <i class="mdi mdi-shield-check" style="font-size: 48px;"></i>
                    <p class="mt-3"><lang>暂无IP白名单记录</lang></p>
                </div>
                <?php endif; ?>
            </div>
        </div>
    </div>
</div>

<!-- 添加/编辑模态框 -->
<div class="modal fade" id="ipWhitelistModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalTitle"><lang>添加IP白名单</lang></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="ipWhitelistForm" onsubmit="saveItem(event)">
                <div class="modal-body">
                    <input type="hidden" id="item_id" name="id" value="0">
                    <div class="mb-3">
                        <label class="form-label"><lang>IP地址</lang> <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="ip" name="ip" required 
                               placeholder="<?= __('例如：192.168.1.1 或 192.168.1.0/24') ?>">
                        <div class="form-text"><lang>支持单个IP或CIDR格式的IP范围</lang></div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label"><lang>描述</lang></label>
                        <textarea class="form-control" id="description" name="description" rows="3"></textarea>
                    </div>
                    <div class="mb-3">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="is_active" name="is_active" value="1" checked>
                            <label class="form-check-label" for="is_active">
                                <lang>启用</lang>
                            </label>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal"><lang>取消</lang></button>
                    <button type="submit" class="btn btn-primary"><lang>保存</lang></button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
(function() {
    'use strict';
    
    window.showAddModal = function() {
        document.getElementById('modalTitle').textContent = '<?= __('添加IP白名单') ?>';
        document.getElementById('item_id').value = '0';
        document.getElementById('ip').value = '';
        document.getElementById('description').value = '';
        document.getElementById('is_active').checked = true;
        new bootstrap.Modal(document.getElementById('ipWhitelistModal')).show();
    };
    
    window.editItem = function(id) {
        BackendToast.info('<?= __('编辑ID：') ?>' + id);
    };
    
    window.saveItem = function(event) {
        event.preventDefault();
        var formData = new FormData(event.target);
        var id = formData.get('id');
        var url = id === '0' 
            ? '<?= $this->getBackendUrl('*/backend/ip-whitelist/add') ?>'
            : '<?= $this->getBackendUrl('*/backend/ip-whitelist/edit') ?>';
        
        fetch(url, {
            method: 'POST',
            body: formData
        })
        .then(function(response) { return response.json(); })
        .then(function(data) {
            if (data.success) {
                BackendToast.success(data.message);
                bootstrap.Modal.getInstance(document.getElementById('ipWhitelistModal')).hide();
                setTimeout(function() {
                    location.reload();
                }, 1000);
            } else {
                BackendToast.error(data.message);
            }
        })
        .catch(function(error) {
            BackendToast.error('<?= __('操作失败') ?>');
        });
    };
    
    window.toggleStatus = function(id, currentStatus) {
        AdminConfirm.show('<?= __('确定要切换状态吗？') ?>').then(function(confirmed) {
            if (!confirmed) return;
            
            var formData = new FormData();
            formData.append('id', id);
            
            var url = '<?= $this->getBackendUrl('*/backend/ip-whitelist/toggle') ?>';
            var opts = { method: 'POST', body: formData };
            window.Weline.Api.request(url, opts)
            .then(function(res) {
                var data = (res && res.data) !== undefined ? res.data : res;
                if (data.success) {
                    BackendToast.success(data.message);
                    setTimeout(function() {
                        location.reload();
                    }, 1000);
                } else {
                    BackendToast.error(data.message);
                }
            })
            .catch(function(error) {
                BackendToast.error('<?= __('操作失败') ?>');
            });
        });
    };
    
    window.deleteItem = function(id) {
        AdminConfirm.show('<?= __('确定要删除这条记录吗？') ?>').then(function(confirmed) {
            if (!confirmed) return;
            
            var formData = new FormData();
            formData.append('id', id);
            
            var url = '<?= $this->getBackendUrl('*/backend/ip-whitelist/delete') ?>';
            var opts = { method: 'POST', body: formData };
            window.Weline.Api.request(url, opts)
            .then(function(res) {
                var data = (res && res.data) !== undefined ? res.data : res;
                if (data.success) {
                    BackendToast.success(data.message);
                    setTimeout(function() {
                        location.reload();
                    }, 1000);
                } else {
                    BackendToast.error(data.message);
                }
            })
            .catch(function(error) {
                BackendToast.error('<?= __('操作失败') ?>');
            });
        });
    };
})();
</script>
