<script>
(function() {
    'use strict';
    
    var form = document.getElementById('roleAddForm');
    var offcanvasElement = document.getElementById('roleAddOffcanvas');
    var offcanvas = null;
    
    // 延迟初始化 offcanvas，确保 Bootstrap 已加载
    function getOffcanvas() {
        if (!offcanvas && typeof bootstrap !== 'undefined' && bootstrap.Offcanvas) {
            offcanvas = bootstrap.Offcanvas.getInstance(offcanvasElement) || new bootstrap.Offcanvas(offcanvasElement);
        }
        return offcanvas;
    }

    function normalizeApiResult(res) {
        if (typeof res === 'string') {
            try {
                return JSON.parse(res);
            } catch (e) {
                return {success: false, message: res};
            }
        }
        if (!res || typeof res !== 'object') {
            return res;
        }
        if (Object.prototype.hasOwnProperty.call(res, 'success') ||
            Object.prototype.hasOwnProperty.call(res, 'code') ||
            Object.prototype.hasOwnProperty.call(res, 'msg') ||
            Object.prototype.hasOwnProperty.call(res, 'message')) {
            return res;
        }
        if (Object.prototype.hasOwnProperty.call(res, 'data')) {
            return normalizeApiResult(res.data);
        }
        return res;
    }

    function apiErrorMessage(error, fallback) {
        var response = error && error.response ? error.response : null;
        var data = response && response.data !== undefined ? normalizeApiResult(response.data) : null;

        if (data && typeof data === 'object') {
            return data.msg || data.message || (data.error && data.error.message) || fallback;
        }
        if (typeof data === 'string' && data.trim()) {
            return data;
        }
        return (error && error.message) || fallback;
    }
    
    var submitting = false;
    form.addEventListener('submit', function(event) {
        event.preventDefault();
        event.stopPropagation();
        
        if (submitting) return;
        if (!form.checkValidity()) {
            form.classList.add('was-validated');
            return;
        }
        submitting = true;
        
        var formData = new FormData(form);
        var data = {};
        for (var pair of formData.entries()) {
            data[pair[0]] = pair[1];
        }
        
        // 禁用提交按钮防止重复提交
        var submitBtn = form.querySelector('button[type="submit"]');
        var originalText = submitBtn.innerHTML;
        submitBtn.disabled = true;
        submitBtn.innerHTML = '<i class="mdi mdi-loading mdi-spin"></i> <?= __('正在创建...') ?>';
        
        BackendToast.info('<?= __('正在创建角色...') ?>');
        
        var roleUrl = '<?= $this->getBackendUrl("*/backend/acl/role/add") ?>';
        var roleOpts = { method: 'POST', headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' }, body: JSON.stringify(data) };
        window.Weline.Api.request(roleUrl, roleOpts)
        .then(function(res) {
            var result = normalizeApiResult(res);
            if (result && result.success) {
                BackendToast.success(result.message || '<?= __('角色创建成功！') ?>');
                var oc = getOffcanvas();
                if (oc) oc.hide();
                form.reset();
                form.classList.remove('was-validated');
                setTimeout(function() {
                    window.location.reload();
                }, 1500);
            } else {
                BackendToast.error(result.message || '<?= __('角色创建失败，请检查输入后重试') ?>');
            }
        })
        .catch(function(error) {
            console.error('Error:', error);
            BackendToast.error(apiErrorMessage(error, '<?= __('角色创建失败，请检查输入后重试') ?>'));
        })
        .finally(function() {
            submitting = false;
            submitBtn.disabled = false;
            submitBtn.innerHTML = originalText;
        });
    });
    
    offcanvasElement.addEventListener('hidden.bs.offcanvas', function() {
        form.reset();
        form.classList.remove('was-validated');
    });
})();
</script>
