<script src='@static(Weline_Acl::libs/vakata-jstree-3.3.14-0/dist/jstree.min.js)'></script>
<script>
(function() {
    'use strict';
    
    var searchTimeout = null;
    var totalPermissions = <?php echo $totalAll; ?>;
    
    var aclTree = $('#acl').jstree({
        'core': {
            'themes': {
                'variant': 'large',
                'responsive': true
            },
            'animation': 150
        },
        'checkbox': {
            'keep_selected_style': false,
            'three_state': true,
            'cascade': 'up'
        },
        'search': {
            'show_only_matches': true,
            'show_only_matches_children': true,
            'search_leaves_only': false,
            'fuzzy': true
        },
        'plugins': ['wholerow', 'checkbox', 'search']
    });
    
    function updateStatistics() {
        var tree = $('#acl').jstree(true);
        if (!tree) return;
        
        var selectedCount = tree.get_selected().length;
        var percent = totalPermissions > 0 ? Math.round((selectedCount / totalPermissions) * 100) : 0;
        
        $('#stat-selected').text(selectedCount);
        $('#stat-percent').text(percent + '%');
        $('#stat-progress').css('width', percent + '%');
    }
    
    $('#acl').on('ready.jstree', function() {
        updateStatistics();
    });
    
    $('#acl').on('select_node.jstree', function () {
        updateStatistics();
    });
    
    $('#acl').on('deselect_node.jstree', function (e, data) {
        var tree = $('#acl').jstree(true);
        var node = data.node;

        if (node.parent !== '#') {
            var parentNode = tree.get_node(node.parent);

            var hasSelectedChildren = parentNode.children.some(function (childId) {
                return tree.is_selected(childId);
            });
            if (!hasSelectedChildren) {
                tree.deselect_node(parentNode);
            }
        }
        if (node.children.length > 0) {
            node.children.forEach(function (childId) {
                tree.deselect_node(childId);
            });
        }
        
        updateStatistics();
    });
    
    $('#save_button').on('click', function (e) {
        var selectedNodes = $('#acl').jstree('get_selected', true);
        
        $('#aclForm input[name="ids[]"]').remove();
        
        $.each(selectedNodes, function () {
            $('#aclForm').append('<input type="hidden" name="ids[]" value="' + this.id + '">');
        });
        
        var $btn = $(this);
        var originalHtml = $btn.html();
        $btn.prop('disabled', true).html('<i class="mdi mdi-loading mdi-spin"></i> <?php echo __("保存中..."); ?>');
        
        setTimeout(function() {
            $btn.closest('form').submit();
        }, 100);
    });
    
    $('#acl-search').on('keyup', function() {
        var searchVal = $(this).val().trim();
        clearTimeout(searchTimeout);
        searchTimeout = setTimeout(function() {
            if (searchVal.length > 0) {
                $('#acl').jstree('search', searchVal);
            } else {
                $('#acl').jstree('clear_search');
                $('#acl-search-result').removeClass('visible');
            }
        }, 300);
    });
    
    $('#acl').on('search.jstree', function(e, data) {
        var count = data.nodes.length;
        var $result = $('#acl-search-result');
        var $text = $('#acl-search-result-text');
        
        if (count > 0) {
            $text.text('<?php echo __("找到"); ?> ' + count + ' <?php echo __("个匹配权限"); ?>');
            $result.addClass('visible');
        } else if ($('#acl-search').val().trim().length > 0) {
            $text.text('<?php echo __("未找到匹配的权限，请尝试其他关键词"); ?>');
            $result.addClass('visible');
        }
    });
    
    $('#acl').on('clear_search.jstree', function() {
        $('#acl-search-result').removeClass('visible');
    });
    
    $('#acl-search-clear').on('click', function() {
        $('#acl-search').val('').focus();
        $('#acl').jstree('clear_search');
        $('#acl-search-result').removeClass('visible');
    });
    
    $('#acl-select-all').on('click', function() {
        $('#acl').jstree('select_all');
        if (typeof BackendToast !== 'undefined') {
            BackendToast.info('<?php echo __("已全选所有权限"); ?>');
        }
    });
    
    $('#acl-deselect-all').on('click', function() {
        $('#acl').jstree('deselect_all');
        if (typeof BackendToast !== 'undefined') {
            BackendToast.info('<?php echo __("已清空所有选择"); ?>');
        }
    });
    
    $('#acl-expand-all').on('click', function() {
        $('#acl').jstree('open_all');
    });
    
    $('#acl-collapse-all').on('click', function() {
        $('#acl').jstree('close_all');
    });
    
    function applyFilters() {
        var moduleFilter = $('#acl-filter-module').val();
        var typeFilter = $('#acl-filter-type').val();
        var tree = $('#acl').jstree(true);
        var visibleCount = 0;
        
        $('#acl li[data-module]').each(function() {
            var $node = $(this);
            var nodeModule = $node.attr('data-module') || '';
            var nodeType = $node.attr('data-type') || '';
            var nodeId = $node.attr('id');
            
            var moduleMatch = !moduleFilter || nodeModule.indexOf(moduleFilter) !== -1;
            var typeMatch = !typeFilter || nodeType === typeFilter;
            
            if (moduleMatch && typeMatch) {
                tree.show_node(nodeId);
                visibleCount++;
            } else {
                tree.hide_node(nodeId);
            }
        });
        
        if ((moduleFilter || typeFilter) && typeof BackendToast !== 'undefined') {
            BackendToast.info('<?php echo __("筛选结果"); ?>: ' + visibleCount + ' <?php echo __("个分组"); ?>');
        }
    }
    
    $('#acl-filter-module, #acl-filter-type').on('change', function() {
        applyFilters();
    });
    
    $(document).on('keydown', function(e) {
        if (e.ctrlKey || e.metaKey) {
            if (e.key === 'f' || e.key === 'F') {
                e.preventDefault();
                $('#acl-search').focus();
            } else if (e.key === 's' || e.key === 'S') {
                e.preventDefault();
                $('#save_button').click();
            }
        }
    });
})();
</script>
