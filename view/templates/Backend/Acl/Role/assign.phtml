        <div class="weline-acl-tree-body">
                
<?php
            /**
             * 使用闭包替代全局函数，避免 WLS 常驻内存模式下 "Cannot redeclare function" 错误
             */
            $getLiAttr = function (\Weline\Acl\Model\RoleAccess|\Weline\Acl\Model\Acl|\Weline\Acl\Model\AclNode $acl): string {
                $type = $acl->getType() ?: '';
                $icon = $acl->getIcon();
                if (empty($icon)) {
                    $icon = match ($type) {
                        'menus' => 'mdi mdi-menu',
                        'pc' => 'mdi mdi-link-variant',
                        default => ''
                    };
                }
                if (empty($icon)) {
                    if ($acl->getMethod()) {
                        $icon = match (strtolower($acl->getMethod())) {
                            'get' => 'mdi mdi-eye-outline',
                            'post' => 'mdi mdi-content-save-outline',
                            'delete' => 'mdi mdi-delete-outline',
                            'put' => 'mdi mdi-pencil-outline',
                            'update' => 'mdi mdi-refresh',
                            default => 'mdi mdi-key-outline'
                        };
                    } else {
                        $icon = 'mdi mdi-key-outline';
                    }
                }
                $desc = $acl->getDocument() ? htmlspecialchars(__($acl->getDocument()), ENT_QUOTES) : '';
                if (empty($desc)) {
                    $desc = match ($type) {
                        'menus' => __('菜单权限'),
                        'pc' => __('接口权限'),
                        default => __('访问权限')
                    };
                }
                $sourceId = htmlspecialchars($acl->getSourceId(), ENT_QUOTES);
                $desc .= " ({$sourceId})";
                $access = $acl->getData('role_id') ? 'true' : 'false';
                return " class='show_tooltip' title='{$desc}' data-jstree='{\"disabled\":false,\"opened\":false,\"selected\":{$access},\"icon\":\"$icon\"}' ";
            };

            $getTreeNode = function (\Weline\Acl\Model\RoleAccess|\Weline\Acl\Model\Acl|\Weline\Acl\Model\AclNode $tree) use (&$getTreeNode, $getLiAttr): string {
                $result = '';
                if ($tree->getSub()) {
                    $result .= '<ul>';
                    foreach ($tree->getSub() as $sub) {
                        $method = $sub->getMethod() ? "({$sub->getMethod()})" : '';
                        $type = $sub->getType();
                        $typeLabel = match ($type) {
                            'menus' => __('菜单'),
                            'pc' => 'ACL',
                            default => __('未知')
                        };
                        $typeClass = match ($type) {
                            'menus' => 'is-menu',
                            'pc' => 'is-acl',
                            default => ''
                        };
                        $typeBadge = " <span class='weline-acl-type-badge {$typeClass}'>" . htmlspecialchars((string)$typeLabel) . '</span>';
                        $attr = $getLiAttr($sub);
                        $sourceName = htmlspecialchars($sub->getSourceName());
                        $result .= "<li id='{$sub->getSourceId()}' {$attr}>{$sourceName}{$method}{$typeBadge}";
                        $result .= $getTreeNode($sub);
                        $result .= '</li>';
                    }
                    $result .= '</ul>';
                }
                return $result;
            };
            ?>
            <div id='acl' class='acl-container'>
                <ul>
                    <foreach name='trees' item='tree'>
                        <?php 
                        $attr = $getLiAttr($tree);
                        $sourceId = $tree->getSourceId();
                        $stat = $statistics[$sourceId] ?? null;
                        $type = $tree->getType();
                        $typeLabel = match ($type) {
                            'menus' => __('菜单'),
                            'pc' => 'ACL',
                            default => __('未知')
                        };
                        $typeClass = match ($type) {
                            'menus' => 'is-menu',
                            'pc' => 'is-acl',
                            default => ''
                        };
                        $typeBadge = "<span class='weline-acl-type-badge {$typeClass}'>" . htmlspecialchars((string)$typeLabel) . "</span>";
                        $statBadge = '';
                        if ($stat) {
                            $selectedCount = $stat['selected'];
                            $totalCount = $stat['total'];
                            $badgeClass = $selectedCount === $totalCount ? 'bg-success' : ($selectedCount > 0 ? 'bg-warning text-dark' : 'bg-secondary');
                            $statBadge = " <span class='weline-acl-module-badge {$badgeClass}'>{$selectedCount}/{$totalCount}</span>";
                        }
                        ?>
                        <li id='{{tree.source_id}}' {{attr}} data-module="<?php echo htmlspecialchars($tree->getModule()); ?>" data-type="<?php echo htmlspecialchars($tree->getType()); ?>">{{tree.source_name}}
                            <if condition="tree.method">
                                ({{tree.method}})
                            </if>
                            <?php echo $typeBadge; ?>
                            <?php echo $statBadge; ?>
                            <?php echo $getTreeNode($tree); ?>
                        </li>
                    </foreach>
                </ul>
            </div>
        </div>
        
