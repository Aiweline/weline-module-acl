/**
 * 内容模板
 * @var \Weline\Framework\View\Template $this
 */

$statistics = $this->getData('tree_statistics') ?: [];
$totalAll = 0;
$selectedAll = 0;
foreach ($statistics as $stat) {
    $totalAll += $stat['total'];
    $selectedAll += $stat['selected'];
}
$selectedPercent = $totalAll > 0 ? round(($selectedAll / $totalAll) * 100) : 0;
