<script>
(function() {
    'use strict';
    
    window.filterByType = function(type) {
        filterTable();
    };
    
    window.filterByModule = function(module) {
        filterTable();
    };
    
    function filterTable() {
        var typeFilter = document.getElementById('acl-filter-type').value.toLowerCase();
        var moduleFilter = document.getElementById('acl-filter-module').value;
        var rows = document.querySelectorAll('#acl-table tbody tr');
        var visibleCount = 0;
        
        rows.forEach(function(row) {
            var rowType = (row.getAttribute('data-type') || '').toLowerCase();
            var rowModule = row.getAttribute('data-module') || '';
            
            var typeMatch = !typeFilter || rowType === typeFilter;
            var moduleMatch = !moduleFilter || rowModule === moduleFilter;
            
            if (typeMatch && moduleMatch) {
                row.style.display = '';
                visibleCount++;
            } else {
                row.style.display = 'none';
            }
        });
        
        document.getElementById('visible-count').textContent = visibleCount;
    }
    
    document.addEventListener('keydown', function(e) {
        if ((e.ctrlKey || e.metaKey) && (e.key === 'f' || e.key === 'F')) {
            e.preventDefault();
            var searchInput = document.querySelector('.weline-acl-search-input input');
            if (searchInput) {
                searchInput.focus();
            }
        }
    });
})();
</script>
