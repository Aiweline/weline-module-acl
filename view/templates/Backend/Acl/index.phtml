$moduleStats = [];
$typeStats = [];
foreach ($acls as $acl) {
    $module = $acl->getModule() ?: 'Unknown';
    $type = $acl->getType() ?: 'other';
    $moduleStats[$module] = ($moduleStats[$module] ?? 0) + 1;
    $typeStats[$type] = ($typeStats[$type] ?? 0) + 1;
}
$moduleCount = count($moduleStats);
$typeCount = count($typeStats);
