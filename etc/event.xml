<?xml version="1.0"?>
<config xmlns:xs="http://www.w3.org/2001/XMLSchema-instance"
        xs:noNamespaceSchemaLocation="urn:Weline_Framework::Event/etc/xsd/event.xsd"
        xmlns="urn:Weline_Framework::Event/etc/xsd/event.xsd">
    <!--控制器注解属性-->
    <event name="Weline_Framework_Module::controller_attributes">
        <observer name="Weline_Acl::controller_attributes" instance="Weline\Acl\Observer\ControllerAttributes" disabled="false"
                  shared="true" sort="0"/>
    </event>
    <event name="Weline_Framework_Router::route_before">
        <observer name="Weline_Acl::route_before" instance="Weline\Acl\Observer\RouteBefore" disabled="false" shared="true" sort="1"/>
    </event>
    <event name="Weline_Framework_Setup::before_route_collection">
        <observer name="Weline_Acl::setup_before_route_collection_clear_registry" instance="Weline\Acl\Observer\ClearCollectedAclRegistry" disabled="false" shared="true" sort="0"/>
    </event>
    <event name="Weline_Framework_Setup::after_route_collection">
        <observer name="Weline_Acl::setup_after_route_collection_acl_diff" instance="Weline\Acl\Observer\AfterRouteCollectionAclDiff" disabled="false" shared="true" sort="0"/>
    </event>
    <event name="Weline_Framework_Setup::cleanup_missing_module_acl_residues">
        <observer name="Weline_Acl::setup_cleanup_missing_module_acl_residues" instance="Weline\Acl\Observer\CleanupMissingModuleAclResidues" disabled="false" shared="true" sort="0"/>
    </event>
    <event name="Weline_Framework_Module::remove_acl_diff_begin">
        <observer name="Weline_Acl::remove_acl_diff_begin_clear_registry" instance="Weline\Acl\Observer\ClearCollectedAclRegistry" disabled="false" shared="true" sort="0"/>
    </event>
    <event name="Weline_Framework_Module::remove_acl_diff_cleanup">
        <observer name="Weline_Acl::remove_acl_diff_cleanup" instance="Weline\Acl\Observer\AfterRouteCollectionAclDiff" disabled="false" shared="true" sort="0"/>
    </event>
    <!-- 系统升级完成后为 role_id=1 授予当前 ACL 全部权限，避免升级后超管无权限 -->
    <event name="Weline_Framework_Setup::upgrade_after">
        <observer name="Weline_Acl::setup_upgrade_grant_super_admin" instance="Weline\Acl\Observer\SetupUpgradeGrantSuperAdmin" disabled="false" shared="true" sort="0"/>
    </event>
</config>